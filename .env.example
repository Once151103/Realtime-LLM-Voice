# =============================================================================
# Realtime Voice AI Agent - Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=8765
LOG_LEVEL=INFO

# --- Ollama LLM ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=kimi-k2.5:cloud
OLLAMA_FALLBACK_MODEL=qwen3.5:27b
OLLAMA_SYSTEM_PROMPT_PATH=../../SOUL.md

# --- STT (faster-whisper) ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=es

# --- TTS (Piper) ---
PIPER_MODEL_PATH=models/piper/es_MX-claude-medium.onnx
PIPER_CONFIG_PATH=models/piper/es_MX-claude-medium.onnx.json
PIPER_SPEAKER_ID=0

# --- VAD (Silero) ---
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_MS=250
VAD_MIN_SILENCE_MS=300

# --- Audio ---
SAMPLE_RATE_INPUT=16000
SAMPLE_RATE_OUTPUT=22050
CHUNK_SIZE_MS=30

# --- Interruption ---
INTERRUPT_FADE_OUT_MS=50
INTERRUPT_REACTION_TARGET_MS=150

# --- Cache ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# --- OpenClaw ---
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=NaJeongMoSaJiMiDaChaeTzu
